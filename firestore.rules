rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all safety gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth status helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Document ID verification helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Incoming document values evaluation helper
    function incoming() {
      return request.resource.data;
    }

    // Existing document values evaluation helper
    function existing() {
      return resource.data;
    }

        // User profile validation rules
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
        && data.keys().size() <= 5
        && data.uid == request.auth.uid
        && data.uid is string
        && data.email is string
        && data.email.size() <= 256
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 128))
        && (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    // Chat message validation rules
    function isValidChatMessage(data) {
      return data.keys().hasAll(['id', 'senderUid', 'senderEmail', 'text', 'createdAt'])
        && data.keys().size() <= 9
        && data.id is string
        && data.id.size() <= 128
        && data.senderUid == request.auth.uid
        && data.senderUid is string
        && data.senderEmail is string
        && data.senderEmail.size() <= 256
        && data.text is string
        && data.text.size() <= 5000
        && (!data.keys().hasAny(['senderDisplayName']) || (data.displayName is string || data.senderDisplayName is string) && (data.senderDisplayName.size() <= 128))
        && (!data.keys().hasAny(['senderPhotoURL']) || (data.senderPhotoURL is string && data.senderPhotoURL.size() <= 1024))
        && (!data.keys().hasAny(['fileURL']) || (data.fileURL is string && data.fileURL.size() <= 2048))
        && (!data.keys().hasAny(['fileName']) || (data.fileName is string && data.fileName.size() <= 256))
        && data.createdAt == request.time;
    }

    // User Profile matching block
    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUserProfile(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUserProfile(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if false;
    }

    // Chat Messages matching block
    match /chat_messages/{messageId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(messageId) && isValidChatMessage(incoming());
      allow update: if false;
      allow delete: if false;
    }
  }
}
